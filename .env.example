DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.example

DB_ENGINE=mysql
MYSQL_DATABASE=zhongbei_info
MYSQL_USER=zhongbei
MYSQL_PASSWORD=change-me
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-root-password

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CACHE_URL=redis://redis:6379/2
PAGE_CACHE_SECONDS=60
PAGE_CACHE_DETAIL_SECONDS=300

AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_DAILY_BUDGET_CNY=0.5
DEEPSEEK_USD_TO_CNY=7.3
DEEPSEEK_MAX_OUTPUT_TOKENS=500
DEEPSEEK_INPUT_CACHE_HIT_USD_PER_MILLION=0.0028
DEEPSEEK_INPUT_CACHE_MISS_USD_PER_MILLION=0.14
DEEPSEEK_OUTPUT_USD_PER_MILLION=0.28
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:0.6b

OCR_PROVIDER=tesseract
TESSERACT_LANG=chi_sim+eng
OCR_MIN_TEXT_LENGTH=500
OCR_MAX_IMAGES_PER_PAGE=3
OCR_ENABLE_FOR_WEB=0

MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=change-meili-key
MEILISEARCH_INDEX=content_items
PUBLIC_SITE_BASE_URL=https://your-domain.example
CRAWL_USER_AGENT=ZhongbeiInfoBot/0.1 (+https://your-domain.example)
CRAWL_DEFAULT_DEPTH=2
CRAWL_MAX_LINKS_PER_SOURCE=50
CRAWL_MAX_LIST_PAGES_PER_SOURCE=8
CRAWL_RETRY_FAILED_URLS_PER_RUN=10
CRAWL_GROUP_PROBE_MIN_SOURCES=3
CRAWL_GROUP_PROBE_SIZE=3
FETCH_TIMEOUT_SECONDS=12
FETCH_CONNECT_TIMEOUT_SECONDS=5
CRAWL_DIRECT_RETRY_ATTEMPTS=2
CRAWL_FORCE_IPV4_DOMAINS=.nuc.edu.cn,nuc.edu.cn
CRAWL_DIRECT_FIRST=1
CRAWL_RELAY_URL=
CRAWL_RELAY_TOKEN=
CRAWL_RELAY_TIMEOUT_SECONDS=20
CRAWL_RELAY_ON_ERRORS=connect,dns,network,timeout,5xx,429
CRAWL_FAILURE_RETRY_BASE_MINUTES=30
CRAWL_FAILURE_RETRY_MAX_MINUTES=1440
CRAWL_NEAR_DUPLICATE_TEXT_THRESHOLD=0.88
CRAWL_EMPLOYMENT_NOTICE_TYPE_IDS=10831,9571544,9571539,10834,9571538,9571532
CRAWL_EMPLOYMENT_PAGE_SIZE=15
